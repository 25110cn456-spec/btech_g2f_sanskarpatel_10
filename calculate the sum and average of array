#include <stdio.h>

int main() {
    int n, i;
    // Use float for sum and average to handle potential decimal results
    float sum = 0, average;

    // Prompt user for the number of elements (n)
    printf("Enter the number of elements: ");
    scanf("%d", &n);

    // Declare an array of size n
    int arr[n];

    // Use a loop to input n numbers into the array and calculate the running sum
    printf("Enter %d numbers:\n", n);
    for (i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
        sum += arr[i]; // Add each element to the sum
    }

    // Calculate the average by dividing the total sum by the number of elements
    average = sum / n;

    // Print the results
    printf("\nSum = %.2f\n", sum);
    printf("Average = %.2f\n", average);

    return 0;
}
