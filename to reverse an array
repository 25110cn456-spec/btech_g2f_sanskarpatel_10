#include <stdio.h>

int main(){
    int arr[100],n,i, temp;
    //input size 
    printf("enter number of element: ");
    scanf("%d", &n);
    
    //input element
    for(i=0;i<n;i++) {
        scanf("%d", &arr[i]);
    }
    //reverse array
    for(i=0;i<n/2; i++) {
        temp = arr[i];
        arr[i] = arr[n - i - 1];
        arr[n - i - 1] = temp;
        }
        //output reversed array
        printf("reversed array:\n");
        for(i=0;i<n; i++) {
            printf("%d", arr[i]);
        }
        return 0;
}
