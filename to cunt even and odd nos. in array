#include <stdio.h>

int main() {
    int arr[] = {12, 19, 45, 69, 98, 23, 4, 10};
    int size = sizeof(arr) / sizeof(arr[0]);
    int even_count = 0;
    int odd_count = 0;
    
    // Iterate through the array elements
    for (int i = 0; i < size; i++) {
        // Check if the remainder when divided by 2 is 0
        if (arr[i] % 2 == 0) {
            even_count++;
        } else {
            odd_count++;
        }
    }
    
    // Print the results
    printf("The array has %d elements.\n", size);
    printf("Number of even elements: %d\n", even_count);
    printf("Number of odd elements: %d\n", odd_count);
    
    return 0;
}
